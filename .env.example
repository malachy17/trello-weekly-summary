# Trello credentials
TRELLO_KEY=your_trello_api_key
TRELLO_TOKEN=your_trello_token
TRELLO_BOARD_ID=your_board_id

# LLM credentials
LLM_API_KEY=your_llm_api_key
LLM_URL=https://api.synthetic.new/v1/chat/completions
LLM_MODEL=syn:large:text

# For Gemini:
# LLM_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent
# LLM_MODEL=gemini-2.0-flash

# Google Drive (OAuth recommended — uses your personal Google account storage)
GOOGLE_DRIVE_FOLDER_ID=your_drive_or_shared_drive_folder_id
GOOGLE_CLIENT_ID=your_oauth_client_id
GOOGLE_CLIENT_SECRET=your_oauth_client_secret
GOOGLE_REFRESH_TOKEN=your_refresh_token

# Optional service account fallback (not recommended — has 0 Drive quota by default)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Letter configuration
SENDER_NAME=Trello Assistant
RECIPIENT_NAME=Adam Toth-Fejel
RECIPIENT_ADDRESS=1953 North 6th Street\nConcord, CA 94519
LOGO_PATH=logo-clear-bg-cropped.png
